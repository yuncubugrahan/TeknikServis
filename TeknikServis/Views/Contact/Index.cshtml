@{
    ViewData["Title"] = "İletişim";
}

<div class="row justify-content-center mt-3">
    <div class="col-md-8">

        <h2 class="mb-4" style="color:#D85A30">📞 İletişim</h2>

        <div class="row g-4">

            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title mb-3" style="color:#D85A30">🏢 Adres</h5>
                        <p class="mb-1"><strong>TeknikServis Merkezi</strong></p>
                        <p class="mb-1">***</p>
                        <p class="mb-1">***/***</p>
                        <p class="mb-0">Türkiye</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title mb-3" style="color:#D85A30">📱 İletişim Bilgileri</h5>
                        <p class="mb-2">
                            <strong>Telefon:</strong>
                            <a href="tel:+*******" class="text-decoration-none">+*********</a>
                        </p>
                        <p class="mb-2">
                            <strong>E-posta:</strong>
                            <a href="mailto:info@teknikservis.com" class="text-decoration-none">info@teknikservis.com</a>
                        </p>
                        <p class="mb-0">
                            <strong>Web:</strong>
                            <a href="#" class="text-decoration-none">www.teknikservis.com</a>
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title mb-3" style="color:#D85A30">🕐 Çalışma Saatleri</h5>
                        <table class="table table-sm table-borderless mb-0">
                            <tr><td>Pazartesi — Cuma</td><td><strong>09:00 — 18:00</strong></td></tr>
                            <tr><td>Cumartesi</td><td><strong>10:00 — 15:00</strong></td></tr>
                            <tr><td>Pazar</td><td><strong class="text-danger">Kapalı</strong></td></tr>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title mb-3" style="color:#D85A30">🌐 Sosyal Medya</h5>
                        <p class="mb-2">
                            <strong>Instagram:</strong>
                            <a href="#" class="text-decoration-none">@@teknikservis</a>
                        </p>
                        <p class="mb-2">
                            <strong>Twitter/X:</strong>
                            <a href="#" class="text-decoration-none">@@teknikservis</a>
                        </p>
                        <p class="mb-0">
                            <strong>LinkedIn:</strong>
                            <a href="#" class="text-decoration-none">TeknikServis</a>
                        </p>
                    </div>
                </div>
            </div>

        </div>

        <div class="card border-0 shadow-sm mt-4">
            <div class="card-body">
                <h5 class="card-title mb-3" style="color:#D85A30">✉️ Bize Mesaj Gönderin</h5>
                <form>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Adınız Soyadınız</label>
                            <input type="text" class="form-control" placeholder="Ahmet Yılmaz" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-posta</label>
                            <input type="email" class="form-control" placeholder="ornek@mail.com" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Mesajınız</label>
                            <textarea class="form-control" rows="4" placeholder="Mesajınızı buraya yazın..."></textarea>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn text-white" style="background:#D85A30">
                                Gönder
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>