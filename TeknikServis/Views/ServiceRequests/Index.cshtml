@model List<TeknikServis.Models.ServiceRequest>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<Microsoft.AspNetCore.Identity.IdentityUser> SignInManager
@{
    ViewData["Title"] = "Servis Talepleri";
    string cs = ViewBag.Search ?? "";
    string csort = ViewBag.Sort ?? "";
    int ccat = ViewBag.CategoryId ?? 0;
}

<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="card border-0 h-100" style="background:#1a1a1a">
            <div class="card-body text-center py-3">
                <div style="font-size:28px; font-weight:700; color:#D85A30">@ViewBag.ToplamTalep</div>
                <div style="font-size:13px; color:#aaa; margin-top:4px">Toplam Talep</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 h-100" style="background:#fff3cd">
            <div class="card-body text-center py-3">
                <div style="font-size:28px; font-weight:700; color:#856404">@ViewBag.Beklemede</div>
                <div style="font-size:13px; color:#856404; margin-top:4px">Beklemede</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 h-100" style="background:#cff4fc">
            <div class="card-body text-center py-3">
                <div style="font-size:28px; font-weight:700; color:#055160">@ViewBag.Islemde</div>
                <div style="font-size:13px; color:#055160; margin-top:4px">İşlemde</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 h-100" style="background:#d1e7dd">
            <div class="card-body text-center py-3">
                <div style="font-size:28px; font-weight:700; color:#0a3622">@ViewBag.Tamamlandi</div>
                <div style="font-size:13px; color:#0a3622; margin-top:4px">Tamamlandı</div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Servis Talepleri</h2>
    @if (User.IsInRole("Admin"))
    {
        <a href="/ServiceRequests/Add" class="btn btn-sm text-white" style="background:#D85A30">+ Yeni Talep</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="get" action="/ServiceRequests/Index" class="row g-2 mb-4">
    <div class="col-md-3">
        <input type="text" class="form-control" name="search"
               placeholder="Müşteri veya cihaz ara..." value="@cs" />
    </div>
    <div class="col-md-3">
        <select class="form-select" name="categoryId">
            <option value="0">-- Tüm Kategoriler --</option>
            @foreach (SelectListItem item in ViewBag.Categories)
            {
                if (item.Value == ccat.ToString())
                {
                    <option value="@item.Value" selected>@item.Text</option>
                }
                else
                {
                    <option value="@item.Value">@item.Text</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3">
        <select class="form-select" name="sort">
            @if (csort == "")
            {
                <option value="" selected>-- Sıralama --</option>
            }
            else
            {
                <option value="">-- Sıralama --</option>
            }
            @if (csort == "date_asc")
            {
                <option value="date_asc" selected>Tarih: Artan</option>
            }
            else
            {
                <option value="date_asc">Tarih: Artan</option>
            }
            @if (csort == "date_desc")
            {
                <option value="date_desc" selected>Tarih: Azalan</option>
            }
            else
            {
                <option value="date_desc">Tarih: Azalan</option>
            }
            @if (csort == "customer_asc")
            {
                <option value="customer_asc" selected>Müşteri: A→Z</option>
            }
            else
            {
                <option value="customer_asc">Müşteri: A→Z</option>
            }
            @if (csort == "customer_desc")
            {
                <option value="customer_desc" selected>Müşteri: Z→A</option>
            }
            else
            {
                <option value="customer_desc">Müşteri: Z→A</option>
            }
            @if (csort == "status_asc")
            {
                <option value="status_asc" selected>Durum: A→Z</option>
            }
            else
            {
                <option value="status_asc">Durum: A→Z</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn text-white w-100" style="background:#D85A30">Uygula</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-warning">Kayıt bulunamadı.</div>
}
else
{
    <table class="table table-bordered table-hover align-middle">
        <thead class="text-white" style="background:#993C1D">
            <tr>
                <th>ID</th>
                <th>Müşteri</th>
                <th>Cihaz</th>
                <th>Kategori</th>
                <th>Tarih</th>
                <th>Durum</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Id</td>
                    <td>@r.CustomerName</td>
                    <td>@r.DeviceName</td>
                    <td>@r.RequestCategory?.Name</td>
                    <td>@r.RequestDate.ToString("dd.MM.yyyy")</td>
                    <td>
                        @{
                            var badgeColor = r.Status switch
                            {
                                "Tamamlandı" => "success",
                                "İşlemde" => "warning",
                                "İptal" => "danger",
                                _ => "secondary"
                            };
                        }
                        <span class="badge bg-@badgeColor">@r.Status</span>
                    </td>
                    <td>
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <a href="/ServiceRequests/Details/@r.Id" class="btn btn-info btn-sm">Detay</a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a href="/ServiceRequests/Update/@r.Id" class="btn btn-warning btn-sm">Düzenle</a>
                            <a href="/ServiceRequests/Remove/@r.Id" class="btn btn-danger btn-sm"
                               onclick="return confirm('Silinsin mi?')">Sil</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}