@model TeknikServis.Models.ServiceRequest
@{
    ViewData["Title"] = "Talebi Düzenle";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-warning">
                <h5 class="mb-0">Talebi Düzenle</h5>
            </div>
            <div class="card-body">
                <form method="post" action="/ServiceRequests/Update">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label">Müşteri Adı</label>
                        <input type="text" class="form-control" name="CustomerName" value="@Model.CustomerName" />
                        <span class="text-danger small">@Html.ValidationMessage("CustomerName")</span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Cihaz Adı</label>
                        <input type="text" class="form-control" name="DeviceName" value="@Model.DeviceName" />
                        <span class="text-danger small">@Html.ValidationMessage("DeviceName")</span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Arıza Açıklaması</label>
                        <textarea class="form-control" name="ProblemDescription" rows="3">@Model.ProblemDescription</textarea>
                        <span class="text-danger small">@Html.ValidationMessage("ProblemDescription")</span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Talep Tarihi</label>
                            <input type="date" class="form-control" name="RequestDate"
                                   value="@Model.RequestDate.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Durum</label>
                            <select class="form-select" name="Status">
                                @foreach (var s in ViewBag.Statuses)
                                {
                                    if (s == Model.Status)
                                    {
                                        <option value="@s" selected>@s</option>
                                    }
                                    else
                                    {
                                        <option value="@s">@s</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Kategori</label>
                        <select class="form-select" name="RequestCategoryId">
                            @foreach (SelectListItem item in ViewBag.Categories)
                            {
                                if (item.Value == Model.RequestCategoryId.ToString())
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">Güncelle</button>
                        <a href="/ServiceRequests/Index" class="btn btn-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>