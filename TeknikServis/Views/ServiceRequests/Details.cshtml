@model TeknikServis.Models.ServiceRequest
@{
    ViewData["Title"] = "Talep Detayı";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header text-white" style="background:#993C1D">
                <h5 class="mb-0">Talep #@Model.Id — Detay</h5>
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr><th style="width:160px">Müşteri</th><td>@Model.CustomerName</td></tr>
                    <tr><th>Cihaz</th><td>@Model.DeviceName</td></tr>
                    <tr><th>Kategori</th><td>@Model.RequestCategory?.Name</td></tr>
                    <tr><th>Tarih</th><td>@Model.RequestDate.ToString("dd.MM.yyyy")</td></tr>
                    <tr><th>Durum</th><td><span class="badge bg-secondary">@Model.Status</span></td></tr>
                    <tr><th>Açıklama</th><td>@Model.ProblemDescription</td></tr>
                </table>
            </div>
            <div class="card-footer">
                <a href="/ServiceRequests/Index" class="btn btn-secondary">← Listeye Dön</a>
                @if (User.IsInRole("Admin"))
                {
                    <a href="/ServiceRequests/Update/@Model.Id" class="btn btn-warning ms-2">Düzenle</a>
                }
            </div>
        </div>
    </div>
</div>